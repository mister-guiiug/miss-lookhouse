{
  "name": "miss-lookhouse",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "Miss LookHouse — PWA de veille immobilière responsable : surveille plusieurs sources d'annonces sur une zone géographique, historise les annonces, détecte les doublons/recyclages, suit l'évolution des prix, classe manuellement et notifie. Collecte responsable (imports, API officielles, connecteurs paramétrables). Local-first par défaut, backend Supabase sécurisé en option.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "cross-env ANALYZE=1 npm run build",
    "preview": "vite preview --base /miss-lookhouse/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -b",
    "icons": "pwa-icons --source public/favicon.svg --out public/icons --maskable",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:types": "supabase gen types typescript --linked > src/backend/database.types.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,css,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@mister-guiiug/dev-wpa-config": "^3.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2",
    "zod": "^4.0.0",
    "zustand": "^5.0.12"
  }
}
