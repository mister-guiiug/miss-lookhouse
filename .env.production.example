# ── Miss LookHouse — build de PRODUCTION (GitHub Pages) ─────────────────
# Vite lit les variables AU BUILD. Pour déployer un site Pages branché sur
# Supabase, copier ce fichier en `.env.production` (VERSIONNÉ volontairement :
# ne contient QUE des valeurs publiques) et renseigner l'URL + la clé anon.
# Sans ces variables, le site déployé reste en mode `local` (démo navigateur).

VITE_BACKEND=supabase
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
VITE_VAPID_PUBLIC_KEY=YOUR_PUBLIC_VAPID_KEY
VITE_GEOCODER_URL=https://api-adresse.data.gouv.fr
